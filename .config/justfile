cli-develop-npm-globals:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! command -v npm >/dev/null 2>&1; then
        echo "[npm-globals] npm is not installed. Run core-develop-asdf or another Node setup flow first." >&2
        exit 1
    fi
    packages=({{npm_global_packages}})
    for pkg in "${packages[@]}"; do
        echo "[npm-globals] Installing/updating ${pkg}"
        npm install -g "$pkg"
    done

cli-config-npm-skills-backup:
    #!/usr/bin/env bash
    set -euo pipefail
    dest="${HOME}/.config/backups/npm-skills"
    mkdir -p "$dest"
    rm -f "$dest/project-skills.json" "$dest/global-skills.json" "$dest/skill-lock.xdg.json" "$dest/skill-lock.legacy-agents.json"

    if ! command -v skills >/dev/null 2>&1; then
        echo "[npm-skills] skills CLI is not installed. Run cli-develop-npm-globals first." >&2
        exit 1
    fi

    node - "$dest" <<'NODE'
    const fs = require("fs");
    const os = require("os");
    const path = require("path");

    const dest = process.argv[2];
    const xdgStateHome = process.env.XDG_STATE_HOME || path.join(os.homedir(), ".local/state");
    const locks = [
      path.join(xdgStateHome, "skills/.skill-lock.json"),
      path.join(os.homedir(), ".agents/.skill-lock.json"),
    ];
    const merged = { version: 1, skills: {} };

    for (const lockPath of locks) {
      if (!fs.existsSync(lockPath)) continue;
      const parsed = JSON.parse(fs.readFileSync(lockPath, "utf8"));
      for (const [name, entry] of Object.entries(parsed.skills || {})) {
        if (!entry || !entry.source || !entry.sourceType) continue;
        merged.skills[name] = entry;
      }
    }

    merged.skills = Object.fromEntries(
      Object.entries(merged.skills).sort(([a], [b]) => a.localeCompare(b)),
    );

    const outPath = path.join(dest, "skills-lock.json");
    fs.writeFileSync(outPath, `${JSON.stringify(merged, null, 2)}\n`, "utf8");

    const names = Object.keys(merged.skills);
    console.log(`[npm-skills] Wrote ${outPath}`);
    console.log(`[npm-skills] Skills: ${names.length ? names.join(", ") : "(none)"}`);
    NODE

    if [[ ! -s "$dest/skills-lock.json" ]]; then
        echo "[npm-skills] Failed to write skills-lock.json" >&2
        exit 1
    fi

    echo "[npm-skills] Review ~/.config/backups/npm-skills before yadm add."

cli-config-npm-skills-restore:
    #!/usr/bin/env bash
    set -euo pipefail
    src="${HOME}/.config/backups/npm-skills"
    if [[ ! -d "$src" ]]; then
        echo "[npm-skills] Missing backup directory: $src" >&2
        exit 1
    fi
    if [[ ! -f "$src/skills-lock.json" ]]; then
        echo "[npm-skills] Missing backup lock: $src/skills-lock.json" >&2
        exit 1
    fi
    if ! command -v skills >/dev/null 2>&1; then
        echo "[npm-skills] skills CLI is not installed. Run cli-develop-npm-globals first." >&2
        exit 1
    fi
    if [[ -e "$HOME/skills-lock.json" ]]; then
        echo "[npm-skills] Refusing to overwrite existing $HOME/skills-lock.json" >&2
        exit 1
    fi

    cp -p "$src/skills-lock.json" "$HOME/skills-lock.json"
    trap 'rm -f "$HOME/skills-lock.json"' EXIT

    (cd "$HOME" && skills experimental_install)
    skills list

    echo "[npm-skills] Restore complete."

