# vi: ft=just tabstop=4 shiftwidth=4 expandtab

set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
export HOMEBREW_NO_ASK := "1"

# Naming convention
#   <primary>-<domain>-<name>[-<os>]
#   - primary: core/system/cli/gui/extra/build
#   - domain: config/develop/media/productivity/db/vm/util/other
#   - optional OS suffix: darwin/linux/termux
# New recipes must follow this convention to be discoverable by `list`/`install`.
primary_categories := "core system cli gui extra build"
domain_categories := "config develop media productivity db vm util other"
asdf_plugins := "nodejs java direnv"
npm_global_packages := "@google/gemini-cli @openai/codex @upstash/context7-mcp clawhub http-server repomix skills"

default:
    @just --justfile "{{justfile()}}" help

help:
    @printf '%s\n' \
    'Purpose:' \
    '  This justfile is the on-demand install and configuration entry point for dotfiles.' \
    '  Use it to install CLI/GUI apps, restore macOS defaults, and configure developer runtimes.' \
    '  Homebrew installs run without confirmation prompts by default.' \
    '' \
    'Recommended flow:' \
    '  1. On a new machine, install core essentials first:' \
    '       just --justfile ~/.config/justfile core-util-essentials-darwin' \
    '  2. Restore selected macOS system preferences:' \
    '       just --justfile ~/.config/justfile system-config-macos-defaults-menu-darwin' \
    '  3. Review and install other apps on demand:' \
    '       just --justfile ~/.config/justfile list' \
    '       just --justfile ~/.config/justfile install-menu main=gui' \
    '' \
    'Common commands:' \
    '  just list [main=core] [domain=develop] [os=darwin] [name=git] [raw=1]' \
    '      - Filter recipes by naming convention.' \
    '  just install <name> [name...]' \
    '      - Resolve recipe names for the current platform and run them.' \
    '  just install-menu [main=core] [domain=develop] [os=linux]' \
    '      - Interactive multi-select install; uses fzf when available.' \
    '  just gui-config-app-config-backup-menu-darwin' \
    '      - Interactive multi-select backup for selected app configs.' \
    '  just gui-config-app-config-restore-menu-darwin' \
    '      - Interactive multi-select restore for selected app configs.' \
    '  just --list' \
    '      - Show all recipes.' \
    '  just platform-info' \
    '      - Show detected platform for debugging.' \
    '' \
    'Naming convention: <primary>-<domain>-<name>[-<os>], for example core-develop-git-darwin.'

platform-info:
    @just/platform.sh

list *filters:
    @JUSTFILE_PATH="{{justfile()}}" just/list.sh {{filters}}

install *packages:
    @JUSTFILE_PATH="{{justfile()}}" TARGET_PLATFORM="$(just/platform.sh)" just/install.sh {{packages}}

install-menu *filters:
    @JUSTFILE_PATH="{{justfile()}}" TARGET_PLATFORM="$(just/platform.sh)" just/install_menu.sh {{filters}}

