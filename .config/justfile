system-config-timemachine-exclusions-darwin:
    #!/usr/bin/env bash
    set -euo pipefail
    exclusions_file="${HOME}/.config/backups/timemachine/exclusions.txt"

    has_destination() {
        tmutil destinationinfo >/dev/null 2>&1
    }

    apply_fixed_path_exclusion() {
        local path="$1"
        if tmutil isexcluded "$path" 2>/dev/null | grep -q '^\[Excluded\]'; then
            echo "[timemachine] Fixed-path exclusion already exists: $path"
            return 0
        fi
        if ! has_destination; then
            echo "[timemachine] Skipping fixed-path exclusion until a Time Machine backup disk is configured: $path"
            return 0
        fi
        echo "[timemachine] Adding fixed-path exclusion: $path"
        if ! sudo tmutil addexclusion -p "$path"; then
            echo "[timemachine] Failed to add fixed-path exclusion: $path" >&2
            echo "[timemachine] Grant Full Disk Access to your terminal app, then rerun this recipe." >&2
            exit 1
        fi
    }

    if [[ ! -f "$exclusions_file" ]]; then
        echo "[timemachine] Missing exclusions file: $exclusions_file" >&2
        exit 1
    fi
    while IFS= read -r raw_path || [[ -n "$raw_path" ]]; do
        [[ -z "$raw_path" || "$raw_path" == \#* ]] && continue
        path="$raw_path"
        case "$path" in
            \~/*) path="${HOME}/${path#\~/}" ;;
            "\$HOME/"*) path="${HOME}/${path#\$HOME/}" ;;
        esac
        case "$path" in
            "$HOME"|"$HOME"/*)
                echo "[timemachine] Excluding user path: $path"
                if [[ ! -e "$path" ]]; then
                    echo "[timemachine] Creating missing directory: $path"
                    mkdir -p "$path"
                fi
                if ! tmutil addexclusion "$path"; then
                    echo "[timemachine] Failed to add user exclusion: $path" >&2
                    exit 1
                fi
                ;;
            /*)
                apply_fixed_path_exclusion "$path"
                ;;
            *)
                echo "[timemachine] Unsupported path. Use ~/ or an absolute path: $raw_path" >&2
                exit 1
                ;;
        esac
    done < "$exclusions_file"

