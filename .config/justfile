system-config-macos-preferences-backup-menu-darwin:
    #!/usr/bin/env bash
    set -euo pipefail
    recipes=(
        system-config-keyboard-shortcuts-backup-darwin
        system-config-trackpad-backup-darwin
        system-config-bluetooth-trackpad-backup-darwin
        system-config-bluetooth-mouse-backup-darwin
        system-config-hid-mouse-backup-darwin
    )
    if command -v fzf >/dev/null 2>&1; then
        selection="$(printf '%s\n' "${recipes[@]}" | fzf -m --prompt='Select backups > ' || true)"
    else
        printf 'fzf is not installed. Enter backup recipe names manually, separated by spaces.\nCandidates: %s\n> ' "${recipes[*]}"
        read -r selection || true
    fi
    [[ -z "${selection:-}" ]] && { echo "No selection made."; exit 0; }
    selection="${selection//$'\n'/ }"
    read -r -a selected <<<"$selection"
    JUSTFILE_PATH="{{justfile()}}" just/backup.sh "${selected[@]}"

