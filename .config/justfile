cli-develop-npm-globals:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! command -v npm >/dev/null 2>&1; then
        echo "[npm-globals] npm 未安装，请先运行 core-develop-asdf 或相关 node 安装流程" >&2
        exit 1
    fi
    packages=({{npm_global_packages}})
    for pkg in "${packages[@]}"; do
        echo "[npm-globals] 安装/更新 ${pkg}"
        npm install -g "$pkg"
    done

