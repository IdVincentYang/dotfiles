core-util-essentials-darwin:
    #!/usr/bin/env bash
    set -euo pipefail
    recipes=(
        core-develop-autoconf
        core-develop-automake
        core-develop-asdf
        core-util-p7zip
        core-util-tree
        core-productivity-zoxide
        core-media-jetbrains-mono-nerd-font
        core-cli-bat
        core-cli-btop
        core-cli-fd
        core-cli-fzf
        core-cli-ripgrep
        core-cli-tealdeer
        core-cli-grsync
        core-cli-rsync
        core-cli-wget
        core-cli-yank
        core-media-yt-dlp
    )
    for recipe in "${recipes[@]}"; do
        just --justfile "{{justfile()}}" "$recipe"
    done

