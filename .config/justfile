_macos-preference-plist-backup name plist:
    #!/usr/bin/env bash
    set -euo pipefail
    src="${HOME}/Library/Preferences/{{plist}}"
    dest="${HOME}/.config/backups/macos/preferences/{{plist}}"
    if [[ ! -f "$src" ]]; then
        echo "[macos-preferences] Missing source plist: $src" >&2
        exit 1
    fi
    mkdir -p "$(dirname "$dest")"
    cp -p "$src" "$dest"
    echo "[macos-preferences] Backed up {{name}}: $dest"

_macos-preference-plist-restore name plist:
    #!/usr/bin/env bash
    set -euo pipefail
    src="${HOME}/.config/backups/macos/preferences/{{plist}}"
    dest="${HOME}/Library/Preferences/{{plist}}"
    if [[ ! -f "$src" ]]; then
        echo "[macos-preferences] Missing backup plist: $src" >&2
        exit 1
    fi
    mkdir -p "$(dirname "$dest")"
    if [[ -e "$dest" ]]; then
        backup="${dest}.before-dotfiles-$(date +%Y%m%d%H%M%S)"
        mv "$dest" "$backup"
        echo "[macos-preferences] Existing plist moved to: $backup"
    fi
    cp -p "$src" "$dest"
    killall cfprefsd 2>/dev/null || true
    killall SystemUIServer 2>/dev/null || true
    echo "[macos-preferences] Restored {{name}}. Logout or reboot recommended."

